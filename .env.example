# FRN-WEB Umgebungsvariablen
# Kopieren nach .env und anpassen

# Whisper-Transkription aktivieren (true/false)
# true  = ~500 MB mehr Image-Größe + ~1.5 GB Modell-Download beim ersten Start
# false = schlankes Image ohne ML (default)
WITH_WHISPER=false

# Ports (optional, Defaults: 8765 und 8000)
TX_PORT=8765
ICECAST_PORT=8000
