# FRN-WEB Umgebungsvariablen
# Kopieren nach .env und anpassen

# FRN_Server.jar Adresse (default: host.docker.internal = Docker-Host)
FRN_SERVER=host.docker.internal
FRN_PORT=10024

# Ports für den TX-Server und Icecast (nach außen)
TX_PORT=8765
ICECAST_PORT=8000

# Icecast Source-Passwort (muss mit config/icecast.xml übereinstimmen)
ICECAST_SOURCE_PASSWORD=ICECAST_SOURCE_PW
